generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model votes {
  id            String   @id @default(cuid())
  fingerprintId String   @unique
  signature     String
  region        String
  ipAddress     String
  createdAt     DateTime @default(now())
}
