// latest fix
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Votes {
  id         String    @id @default(cuid())
  email      String?   @unique
  signature  String?
  region     String
  createdAt  DateTime  @default(now())
}
